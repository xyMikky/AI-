# AI设计师助手 - API 配置模板
# 使用方法：复制本文件为 .env，填入真实 key 后使用
# 此文件可提交到版本控制；.env 不可提交

# ==========================================
# RunningHub API（生图服务）
# ==========================================
RH_API_KEY=your_runninghub_api_key_here
RH_API_BASE_URL=https://www.runninghub.cn/openapi/v2
RH_API_TIMEOUT=60
RH_API_POLLING_INTERVAL=5
RH_API_MAX_POLLING_TIME=240
RH_UPLOAD_TIMEOUT=60

# ==========================================
# SiliconFlow Embedding API（向量检索系统）
# ==========================================
SILICONFLOW_API_KEY=your_siliconflow_api_key_here
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B
EMBEDDING_DIM=4096
EMBEDDING_BATCH_SIZE=10
EMBEDDING_TIMEOUT=60
EMBEDDING_MAX_RPM=1600
