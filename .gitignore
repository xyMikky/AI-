# ============================================
# AI设计师助手 · 敏感与临时文件忽略规则
# ============================================

# API Keys & 敏感配置
config/.env
**/.env
!**/.env.example

# Python 缓存
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# 向量索引（可重建，无需版本控制）
工具/向量检索/vector_index/*.npz
工具/向量检索/vector_index/*.parquet
工具/向量检索/vector_index/*.cache
工具/向量检索/vector_index/manifest.json

# 临时文件
*.tmp
*.log
_tmp_*.py
.DS_Store
Thumbs.db

# 生成输出（用户产出，可能很大）—— 统一输出根目录：生成结果输出/
生成结果输出/**/*.png
生成结果输出/**/*.jpg
生成结果输出/**/*.jpeg
生成结果输出/**/*.webp
生成结果输出/**/*.html
!生成结果输出/.gitkeep
!生成结果输出/输出目录说明.txt

# 输入素材（用户提供，按需保留）
输入图片/**/*.png
输入图片/**/*.jpg
输入图片/**/*.jpeg
输入图片/**/*.webp
!输入图片/.gitkeep
!输入图片/输入目录说明.txt

# IDE
.vscode/settings.json
.idea/
